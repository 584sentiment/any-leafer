{
  "name": "resume-editor-leafer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "基于 LeaferJS 的图形编辑器/简历编辑器",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:worker": "node scripts/dev.js worker",
    "dev:demo": "node scripts/dev.js demo",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
