{
  "name": "@resume-editor/client",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@leafer-in/editor": "^1.4.0",
    "@leafer-in/export": "^1.4.0",
    "@leafer-in/resize": "^1.4.0",
    "@leafer-in/text-editor": "^2.0.3",
    "@leafer-in/view": "^1.4.0",
    "@leafer-in/viewport": "^2.0.3",
    "@resume-editor/shared": "workspace:*",
    "@resume-editor/templates": "workspace:*",
    "leafer-ui": "^1.4.0",
    "leafer-x-dotwuxian": "^0.0.3",
    "lucide-react": "^0.577.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.8",
    "fast-check": "^3.23.1",
    "happy-dom": "^15.11.7",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
